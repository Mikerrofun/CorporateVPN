# ── Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=

# ── Redis (rate limiting) ────────────────────────────────────────────
# В docker-compose задается автоматически (redis://redis:6379).
# Для локальной разработки: redis://localhost:6379 (пусто = rate limiting выключен)
REDIS_URL=

# ── NextAuth ─────────────────────────────────────────────────────────
# openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ── Admin credentials (выдаются компании при продаже) ────────────────
# Логин — произвольная строка
ADMIN_LOGIN=
# Bcrypt hash пароля. Сгенерить: node -e "require('bcryptjs').hash('пароль',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# ── Shared secret между Next.js и Python backend ─────────────────────
# openssl rand -hex 32
INTERNAL_API_SECRET=
BACKEND_URL=

# ── Marzban ──────────────────────────────────────────────────────────
MARZBAN_BASE_URL=
MARZBAN_USERNAME=
MARZBAN_PASSWORD=
MARZBAN_TLS_CA_FILE=

# ── Публичный базовый URL для ссылок подписки ────────────────────────
SUBSCRIPTION_PUBLIC_BASE_URL=

# ── Telegram бот для тикетов поддержки ───────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=
