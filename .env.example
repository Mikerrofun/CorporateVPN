# ── Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=

# ── NextAuth ─────────────────────────────────────────────────────────
# openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ── Shared secret between web (Next.js) and backend (FastAPI) ───────
# openssl rand -hex 32 — used on internal-only calls, never exposed to the browser.
INTERNAL_API_SECRET=
BACKEND_URL=

# ── Marzban (already running in Docker on the VPS, port 8002) ───────
# Point this at wherever Marzban's API is actually reachable from the backend
# container. If both stacks run on the same VPS, http://host.docker.internal:8002
# (Linux: add `extra_hosts: ["host.docker.internal:host-gateway"]`, already set
# below) works without joining Marzban's docker network. If you'd rather attach
# directly to Marzban's compose network, set MARZBAN_DOCKER_NETWORK to its name
# (`docker network ls` on the VPS) and swap MARZBAN_BASE_URL to the container name.
MARZBAN_BASE_URL=
MARZBAN_USERNAME=
MARZBAN_PASSWORD=
MARZBAN_TLS_CA_FILE=

# ── Public subscription gateway base (used to build /sub/<token> links) ─
SUBSCRIPTION_PUBLIC_BASE_URL=

# ── Bootstrap admin (used only by `npm run seed` inside web/, once) ──
# Leave unset to auto-generate a password/company code — see ADMIN_CREDENTIALS.txt
# after running the seed.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_COMPANY_NAME=
ADMIN_COMPANY_CODE=
