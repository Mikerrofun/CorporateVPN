// Data model для корпоративного VPN сервиса.
// Один деплой = одна компания-клиент.
// Admin хранится в .env (ADMIN_LOGIN + ADMIN_PASSWORD_HASH) — не в БД.
// БД содержит только группы сотрудников и самих сотрудников.
//
// Python backend (FastAPI) не трогает Postgres напрямую — только Marzban через HTTP.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  BANNED
}

enum GroupStatus {
  ACTIVE
  SUSPENDED
}

enum TicketTopic {
  CONNECTION
  SPEED
  ACCOUNT
  OTHER
}

enum TicketStatus {
  OPEN
  CLOSED
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Группа сотрудников. У каждой группы свой Marzban аккаунт и ссылка подписки.
/// Admin создаёт группу и задаёт inviteCode + maxMembers.
model Group {
  id         String      @id @default(cuid())
  name       String
  /// Инвайт-код который admin раздаёт сотрудникам для регистрации.
  inviteCode String      @unique
  /// Максимальное количество участников — задаёт admin при создании.
  maxMembers Int
  status     GroupStatus @default(ACTIVE)

  /// Marzban аккаунт группы (один на всю группу).
  marzbanUsername String? @unique
  /// Ссылка подписки Hiddify/Outline — одна на всю группу.
  subscriptionUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members User[]
  tickets SupportTicket[]

  @@map("groups")
}

/// Сотрудник компании. Регистрируется по inviteCode группы.
model User {
  id           String     @id @default(cuid())
  /// Логин — используется при входе.
  login        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets SupportTicket[]

  @@index([groupId])
  @@map("users")
}

/// Обращение в поддержку. Уведомление уходит в Telegram-бота.
model SupportTicket {
  id        String       @id @default(cuid())
  groupId   String
  group     Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     TicketTopic
  message   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([groupId, status])
  @@map("support_tickets")
}

/// Аудит-лог действий администратора.
model AdminAuditLog {
  id           String   @id @default(cuid())
  adminLogin   String
  action       String
  targetUserId String?
  details      String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@map("admin_audit_logs")
}
